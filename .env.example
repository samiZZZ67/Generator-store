# ─── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Store Config ──────────────────────────────────────────
WA_NUMBER=251911234567
STORE_NAME=ጀነሬተር ስቶር
STORE_PHONE=+251911234567

# ─── Admin ─────────────────────────────────────────────────
# Change this before going live — used to access the /admin page and api routes
ADMIN_SECRET=change-me-before-deploy

# ─── Database ──────────────────────────────────────────────
# Leave blank in local development to automatically use SQLite fallback (data/store.db)
# On Render production, link this to your PostgreSQL Connection String
DATABASE_URL=postgresql://user:password@host:port/database

# ─── Telegram Bot Notifications ────────────────────────────
# Token received from BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
# Comma-separated list of Telegram Chat IDs to send notifications to (supports 1 to 5+ chat IDs)
TELEGRAM_CHAT_IDS=111111111,222222222,333333333

# ─── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all in dev)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
